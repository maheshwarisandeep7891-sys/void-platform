# ═══════════════════════════════════════════════════════════════
# VOID Platform — Environment Variables
# Copy this file to .env.local and fill in all values
# ═══════════════════════════════════════════════════════════════

# ─── DATABASE ────────────────────────────────────────────────────
# Supabase PostgreSQL connection string
# Get from: https://supabase.com → Project Settings → Database → Connection string
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# ─── REDIS ───────────────────────────────────────────────────────
# Upstash Redis URL
# Get from: https://console.upstash.com → Create Database → REST API → UPSTASH_REDIS_REST_URL
REDIS_URL="rediss://:[PASSWORD]@[HOST].upstash.io:6379"
UPSTASH_REDIS_URL="rediss://:[PASSWORD]@[HOST].upstash.io:6379"

# ─── NEXTAUTH ────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-key-here-generate-with-openssl"
NEXTAUTH_URL="https://your-void-app.vercel.app"

# ─── GITHUB OAUTH ────────────────────────────────────────────────
# Get from: https://github.com/settings/developers → New OAuth App
# Homepage URL: https://your-void-app.vercel.app
# Callback URL: https://your-void-app.vercel.app/api/auth/callback/github
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# ─── GOOGLE OAUTH ────────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: https://your-void-app.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─── STRIPE ──────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_PUBLISHABLE_KEY="pk_live_..."
# Get from: https://dashboard.stripe.com/webhooks → Add endpoint
# Endpoint URL: https://your-void-app.vercel.app/api/stripe/webhook
# Events: payment_intent.succeeded, payment_intent.payment_failed, transfer.created
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─── CLOUDFLARE R2 ───────────────────────────────────────────────
# Get from: https://dash.cloudflare.com → R2 → Create bucket
# Account ID: https://dash.cloudflare.com → Right sidebar
CLOUDFLARE_ACCOUNT_ID="your-cloudflare-account-id"
# R2 API tokens: https://dash.cloudflare.com → R2 → Manage R2 API Tokens
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="void-platform"
# Public URL for your R2 bucket (enable public access in R2 settings)
R2_PUBLIC_URL="https://pub-[hash].r2.dev"

# ─── RESEND (EMAIL) ──────────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY="re_..."
EMAIL_FROM="VOID <noreply@void.dev>"

# ─── SENTRY ──────────────────────────────────────────────────────
# Get from: https://sentry.io → New Project → Next.js
SENTRY_DSN="https://[key]@[org].ingest.sentry.io/[project-id]"
SENTRY_ORG="your-sentry-org"
SENTRY_PROJECT="void-platform"
SENTRY_AUTH_TOKEN="your-sentry-auth-token"

# ─── DARK MODE ───────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
DARK_MODE_SALT="your-dark-mode-salt-here"

# ─── MEILISEARCH (OPTIONAL) ──────────────────────────────────────
# Get from: https://cloud.meilisearch.com OR self-host on Railway
MEILISEARCH_HOST="https://[instance].meilisearch.io"
MEILISEARCH_API_KEY="your-meilisearch-api-key"

# ─── APP ─────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://your-void-app.vercel.app"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."
